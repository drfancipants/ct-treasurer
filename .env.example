# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma — uses Supabase connection pooler
DATABASE_URL="postgresql://postgres.your-ref:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-ref:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Anedot webhook — generate a random secret and add it in Anedot's webhook settings
ANEDOT_WEBHOOK_SECRET=your-random-secret-here

# Plaid — sandbox keys from https://dashboard.plaid.com
PLAID_CLIENT_ID=your-client-id
PLAID_SECRET=your-sandbox-secret
PLAID_ENV=sandbox

# Supabase service role key — for admin operations (invite users, bypass RLS)
# Find this in your Supabase project → Settings → API → service_role key
# NEVER expose this to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your app's public URL — used to build invite redirect links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — create keys at https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_...
# Price ID for your monthly subscription product (create in Stripe Dashboard → Products)
STRIPE_PRICE_ID=price_...
# Webhook signing secret from Stripe Dashboard → Webhooks (stripe listen --print-secret for local dev)
STRIPE_WEBHOOK_SECRET=whsec_...
