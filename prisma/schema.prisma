generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

// ─── Committees (tenants) ────────────────────────────────────────────────────

model Committee {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  seecId          String?  // SEEC registration ID (e.g. CT-DTC-20240142)
  anedotAccountId String?  @unique // Anedot account UID for webhook routing
  address1        String?
  address2     String?
  city         String?
  state        String   @default("CT")
  zip          String?
  phone        String?
  email        String?
  electionYear         Int?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus?
  trialEndsAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  memberships   CommitteeMembership[]
  contributions Contribution[]
  expenditures  Expenditure[]
  bankAccounts  BankAccount[]
  seecFilings   SeecFiling[]
  events        Event[]
  committeeContributions CommitteeContribution[]
  inKindContributions    InKindContribution[]
  reimbursements         Reimbursement[]
}

// ─── Users & membership ──────────────────────────────────────────────────────

model User {
  id        String   @id // Matches Supabase auth.users.id
  email     String   @unique
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships CommitteeMembership[]
}

model CommitteeMembership {
  id          String     @id @default(cuid())
  userId      String
  committeeId String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@unique([userId, committeeId])
  @@index([committeeId])
}

enum MemberRole {
  TREASURER
  ASSISTANT_TREASURER
  CHAIRPERSON
  SECRETARY
  MEMBER
  VIEWER
}

// ─── Donors & contributions ──────────────────────────────────────────────────

model Contributor {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  address1   String
  address2   String?
  city       String
  state      String   @default("CT")
  zip        String
  employer   String?  // Required by SEEC for itemized contributions
  occupation String?  // Required by SEEC for itemized contributions
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contributions Contribution[]
}

model Contribution {
  id            String             @id @default(cuid())
  committeeId   String
  contributorId String
  amount        Decimal            @db.Decimal(10, 2)
  date          DateTime           @db.Date
  method        PaymentMethod
  checkNumber   String?
  memo          String?
  source        ContributionSource @default(MANUAL)
  anedotId      String?            @unique // Deduplication key for Anedot imports
  isItemized    Boolean            @default(true)
  filedAt       DateTime?          // Stamped when the covering period is marked filed
  eventId       String?            // Linked fundraising event (SEEC Section B event columns)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  committee   Committee   @relation(fields: [committeeId], references: [id])
  contributor Contributor @relation(fields: [contributorId], references: [id])
  event       Event?      @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([committeeId, date])
  @@index([contributorId])
}

enum PaymentMethod {
  CHECK
  CASH
  CREDIT_CARD
  DEBIT_CARD
  ONLINE
  OTHER
}

enum ContributionSource {
  MANUAL
  ANEDOT
  BANK_IMPORT
}

// ─── Contributions from other committees (SEEC Form 20 Section C1) ────────────

model CommitteeContribution {
  id            String   @id @default(cuid())
  committeeId   String   // the receiving committee
  fromName      String   // Name of the contributing committee
  treasurerName String?
  street        String?
  city          String?
  state         String   @default("CT")
  zip           String?
  date          DateTime @db.Date
  amount        Decimal  @db.Decimal(10, 2)
  eventId       String?  // optional link to an L1 event
  memo          String?
  filedAt       DateTime? // Stamped when the covering period is marked filed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([committeeId, date])
}

// ─── In-kind contributions (SEEC Form 20 Section M) ───────────────────────────

model InKindContribution {
  id            String   @id @default(cuid())
  committeeId   String
  entityType    String   @default("IS") // IS = Individual/Sole Prop, CO = Committee, OT = Other
  lastName      String                  // person's last name, or entity name
  firstName     String?
  middleInitial String?
  entityName    String?                 // "Name of Committee" column (for CO/OT)
  street        String?
  city          String?
  state         String   @default("CT")
  zip           String?
  date          DateTime @db.Date
  fairMarketValue Decimal @db.Decimal(10, 2)
  description   String
  isStateContractorPrincipal Boolean @default(false)
  contractorBranch String?             // E | L | B (when the above is Y)
  isLobbyist    Boolean  @default(false)
  eventId       String?
  memo          String?
  filedAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([committeeId, date])
}

// ─── Fundraising events (SEEC Form 20 Section L1) ────────────────────────────

model Event {
  id                  String   @id @default(cuid())
  committeeId         String
  date                DateTime @db.Date
  letter              String   // Event # letter (A, B, C…), unique per committee
  description         String
  isFundraiser        Boolean  @default(true)
  street              String?
  city                String?
  state               String   @default("CT")
  zip                 String?
  isPersonalResidence Boolean  @default(false)
  hadDonatedGoods     Boolean  @default(false) // goods/services donated (business ≤$200 / individual ≤$100)
  wasTagSale          Boolean  @default(false) // tag sale, auction, or sale of donated items
  hadProgramBook      Boolean  @default(false) // advertising space sold in a program book
  soldFoodAtFair      Boolean  @default(false) // sold food/beverage at a fair or mass gathering
  foodReceipts        Decimal  @default(0) @db.Decimal(10, 2)
  tagSaleReceipts     Decimal  @default(0) @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  committee     Committee      @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  contributions Contribution[]
  expenditures  Expenditure[]
  committeeContributions CommitteeContribution[]
  inKindContributions    InKindContribution[]
  reimbursements         Reimbursement[]

  @@index([committeeId, date])
}

// ─── Expenditures ────────────────────────────────────────────────────────────

model Expenditure {
  id          String        @id @default(cuid())
  committeeId String
  amount      Decimal       @db.Decimal(10, 2)
  date        DateTime      @db.Date
  payee       String
  purpose     String
  // SEEC Section P purpose code (e.g. "A-RAD", "PRNT") — see lib/types.ts
  category    String        @default("MISC")
  method      PaymentMethod
  checkNumber String?
  memo        String?
  filedAt     DateTime?     // Stamped when the covering period is marked filed
  eventId     String?       // Linked fundraising event (SEEC Section P event columns)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  committee Committee @relation(fields: [committeeId], references: [id])
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  reimbursements Reimbursement[]

  @@index([committeeId, date])
}

// ─── Worker reimbursements (SEEC Form 20 Section T) ──────────────────────────

model Reimbursement {
  id                  String   @id @default(cuid())
  committeeId         String
  workerLastName      String
  workerFirstName     String
  workerMiddleInitial String?
  description         String   // items the worker purchased
  date                DateTime @db.Date // date the worker paid the vendor
  amount              Decimal  @db.Decimal(10, 2)
  method              PaymentMethod @default(CHECK)
  checkNumber         String?
  vendorName          String?
  street              String?
  city                String?
  state               String   @default("CT")
  zip                 String?
  // SEEC Section P purpose code (e.g. "PRNT") — see lib/types.ts
  category            String   @default("MISC")
  expenditureId       String?  // the Section P reimbursement payment this itemizes
  eventId             String?
  memo                String?
  filedAt             DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  committee   Committee    @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  expenditure Expenditure? @relation(fields: [expenditureId], references: [id], onDelete: SetNull)
  event       Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([committeeId, date])
}

// ─── Bank accounts & transactions ────────────────────────────────────────────

model BankAccount {
  id               String    @id @default(cuid())
  committeeId      String
  plaidAccountId   String?   @unique
  plaidItemId      String?
  plaidAccessToken String?
  syncCursor       String?
  name             String
  institution      String?
  accountType      String?
  lastFour         String?
  currentBalance   Decimal?  @db.Decimal(10, 2)
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())

  committee    Committee     @relation(fields: [committeeId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id                    String   @id @default(cuid())
  bankAccountId         String
  plaidTransactionId    String?  @unique
  amount                Decimal  @db.Decimal(10, 2)
  date                  DateTime @db.Date
  description           String
  merchantName          String?
  category              String?
  matchType             String   @default("UNMATCHED")
  matchedContributionId String?
  matchedExpenditureId  String?
  isReconciled          Boolean  @default(false)
  createdAt             DateTime @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([bankAccountId, date])
}

// ─── SEEC filings ────────────────────────────────────────────────────────────

model SeecFiling {
  id          String       @id @default(cuid())
  committeeId String
  formType    SeecFormType
  periodStart DateTime     @db.Date
  periodEnd   DateTime     @db.Date
  status      FilingStatus @default(DRAFT)
  pdfUrl      String?
  notes       String?
  filedAt     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  committee Committee @relation(fields: [committeeId], references: [id])

  @@unique([committeeId, formType, periodStart, periodEnd])
  @@index([committeeId])
}

enum SeecFormType {
  FORM_1    // Committee registration
  FORM_20   // Campaign finance disclosure
  FORM_21   // Related party expenditure
  FORM_30   // Dissolution
}

enum FilingStatus {
  DRAFT
  READY
  FILED
  AMENDED
}
